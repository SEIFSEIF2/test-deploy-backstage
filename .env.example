NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (Calendar + Drive). Same client powers:
#   - meeting Calendar events + Meet links
#   - task-image attachments uploaded into Drive ('drive.file' scope)
#
# Setup checklist when bringing a new project up:
#   1. Create an OAuth 2.0 Client ID under console.cloud.google.com.
#   2. Enable BOTH "Google Calendar API" and "Google Drive API" on the
#      same project (https://console.cloud.google.com/apis/library).
#      Forgetting Drive is the #1 cause of "Drive API has not been used
#      in project X" upload failures.
#   3. Add the redirect URI for each env (prod + local) to the OAuth
#      client. Local default: http://localhost:3000/api/google/oauth/callback
#   4. Connect via /dashboard/settings as an admin.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional - only needed when the callback URL differs from
# NEXT_PUBLIC_SITE_URL/api/google/oauth/callback (e.g. behind a proxy).
GOOGLE_OAUTH_REDIRECT_URI=
