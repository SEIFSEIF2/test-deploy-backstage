# App identity (safe to change per deploy — every user-facing brand
# string reads through lib/config.ts, so no source edits needed).
NEXT_PUBLIC_APP_NAME=Backstage
NEXT_PUBLIC_APP_TAGLINE=Team ops in one place.
NEXT_PUBLIC_APP_EMAIL_DOMAIN=example.com
NEXT_PUBLIC_TIMEZONE=UTC
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# Legacy alias for NEXT_PUBLIC_APP_URL. Kept for backwards compat.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase. If you deploy with the Supabase Vercel integration, these
# three are populated automatically — do not set them manually there.
# For local dev, grab them from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Powers Google Calendar / Meet and (later) Drive attachments.
# 1. Create an OAuth 2.0 Client ID under console.cloud.google.com.
# 2. Enable "Google Calendar API" (add "Google Drive API" for attachments).
# 3. Add the redirect URI for each env (prod + local) to the OAuth
#    client. Local default: http://localhost:3000/api/google/oauth/callback
# 4. Connect via /dashboard/settings as an admin.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Optional. Outbound email (Resend). Leaving these blank silently no-ops
# email notifications so the app still works.
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# Optional, build-time only. When set, `pnpm build` applies
# supabase/migrations/*.sql before compiling (scripts/migrate.mjs).
# The Vercel-Supabase integration injects POSTGRES_URL automatically;
# leave blank for local dev if you use `supabase db push` instead.
POSTGRES_URL=
