NEXT_PUBLIC_SITE_URL=

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Database (Supabase). Get from Supabase Dashboard → Settings → Database →
# *Session pooler* tab (NOT Transaction pooler — that strips advisory locks
# and breaks `prisma migrate`; see docs/decisions/0007). Port 5432 (not
# 6543, that's the Transaction pooler), host
# `aws-N-<region>.pooler.supabase.com`, user `postgres.<project_ref>`.
# Prisma 7 takes a single URL — both the runtime pg adapter and
# `prisma migrate` read it from here. Boundary: the `auth.*` schema is
# owned by Supabase, not Prisma — see docs/decisions/0002. Migration
# workflow lives in docs/decisions/0006.
DATABASE_URL=

# Supabase client (anon, public). Get from Supabase Dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (SECRET, server-only). Used by prisma/seed.ts to create
# auth users via the admin API. NEVER prefix with NEXT_PUBLIC_ — it bypasses
# RLS and can do anything in this project. Get from Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=
