NEXT_PUBLIC_SITE_URL=

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Database (Supabase). Two URLs, same project, different poolers — see
# docs/decisions/0007 (revised).
#
# DATABASE_URL — *Session pooler* (port 5432), used by `prisma migrate`.
# Session mode keeps advisory locks intact; transaction mode strips them
# and the migrate engine hangs. Host `aws-N-<region>.pooler.supabase.com`,
# user `postgres.<project_ref>`. Boundary: the `auth.*` schema is owned by
# Supabase, not Prisma — see docs/decisions/0002. Migration workflow
# lives in docs/decisions/0006.
DATABASE_URL=

# APP_DATABASE_URL — *Transaction pooler* (port 6543), used by the runtime
# pg adapter in lib/prisma.ts. Same host + user as DATABASE_URL, only the
# port differs. Transaction mode multiplexes Postgres connections so the
# dashboard's parallel-query fan-out doesn't exhaust the Session pooler's
# 15-client cap (EMAXCONNSESSION). Safe with @prisma/adapter-pg because
# the adapter doesn't cache named prepared statements by default.
APP_DATABASE_URL=

# Supabase client (anon, public). Get from Supabase Dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (SECRET, server-only). Used by prisma/seed.ts to create
# auth users via the admin API. NEVER prefix with NEXT_PUBLIC_ — it bypasses
# RLS and can do anything in this project. Get from Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=
