# Verbivore Backstage - dev env template.
#
# Supabase project: "Backstage" (ref nkvgvfdmtvdabtpppanj)
# URL:              https://nkvgvfdmtvdabtpppanj.supabase.co
# Region:           eu-central-1, Postgres 17
#
# How to fill this:
# 1. Copy this file to .env.local.
# 2. Grab the values from
#    https://supabase.com/dashboard/project/nkvgvfdmtvdabtpppanj/settings/api
#    (anon key + service role) and
#    https://supabase.com/dashboard/project/nkvgvfdmtvdabtpppanj/settings/database
#    (transaction pooler URL for APP_DATABASE_URL, session pooler URL for DATABASE_URL).
# 3. The anon key is also published as the "publishable" key
#    sb_publishable_ZBmsV8y87knKhtvIn4Vwug_ofJh8fW3 - either form works
#    with @supabase/supabase-js.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Transaction pooler (port 6543) - used at runtime by lib/prisma.ts.
APP_DATABASE_URL=

# Session pooler - used by `prisma migrate` (needs advisory locks).
# Once the migration to Supabase is complete this can be dropped.
DATABASE_URL=

NEXT_PUBLIC_SUPABASE_URL=https://nkvgvfdmtvdabtpppanj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
