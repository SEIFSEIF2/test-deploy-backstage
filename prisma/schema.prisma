// Backstage — Prisma schema.
//
// Scope: slice-1 tables (company, crew_member, project, task) plus the
// slice-2 handoff. Source-of-truth specs:
//   docs/backstage-os-slice-1-plan.md §4
//   docs/backstage-os-slice-2-plan.md §4
//   docs/decisions/0004-prisma-schema-scope.md
//   docs/decisions/0015-slice-2-handoff-architecture.md
//
// Boundary: the `auth.users` table is owned by Supabase and is NOT
// modeled here. crew_member.id receives its value from Supabase Auth
// and is linked by a hand-written FK appended to the init migration.
// See docs/decisions/0002-supabase-prisma-boundary.md.

generator client {
  provider = "prisma-client-js"
}

// url + directUrl live in prisma.config.ts at the repo root.
// See docs/decisions/0007-prisma-7-adapter-pattern.md.
//
// Single-schema (public). The original `crew_member.id → auth.users.id` FK
// from decision 0002 was dropped during slice 2 because Prisma 7's drift
// detection couldn't tolerate the cross-schema constraint without enumerating
// every Supabase auth table — see decision 0016 for the revised boundary.
datasource db {
  provider = "postgresql"
}

enum AccessTier {
  admin
  lead
  member

  @@map("access_tier")
}

enum ProjectKind {
  standard
  operations

  @@map("project_kind")
}

enum TaskStatus {
  backlog
  unscoped
  todo
  in_progress
  in_review
  done
  canceled
  duplicate

  @@map("task_status")
}

enum TaskPriority {
  urgent
  high
  medium
  low
  none

  @@map("task_priority")
}

enum RelationKind {
  blocked_by
  blocks
  parent
  sub_issue
  triage

  @@map("relation_kind")
}

enum CycleStatus {
  completed
  current
  upcoming

  @@map("cycle_status")
}

enum HandoffStatus {
  in_progress
  blocked
  ready_for_review
  done

  @@map("handoff_status")
}

model Company {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  crewMembers  CrewMember[]
  projects     Project[]
  tasks        Task[]
  handoffs     Handoff[]
  labels       Label[]
  comments     TaskComment[]
  activityLogs ActivityLog[]
  cycles       Cycle[]
  externalRefs TaskExternalRef[]
  projectExternalRefs ProjectExternalRef[]

  @@map("company")
}

model CrewMember {
  // INVARIANT: `id` is the matching `auth.users.id` from Supabase Auth.
  // Never use a generated UUID here. Every code path that inserts a
  // crew_member row MUST pass the auth user's id (see prisma/seed.ts and any
  // future signup flow). No default — Prisma will refuse to insert without
  // an explicit id, which is the safety belt that catches mistakes.
  //
  // This was enforced by a DB-level FK in slice 1; the FK was dropped in
  // slice 2 because Prisma 7's drift detector fights cross-schema FKs to
  // Supabase's auth tables. See decisions 0002 (superseded) and 0016.
  id             String     @id @db.Uuid
  companyId      String     @map("company_id") @db.Uuid
  email          String
  // URL-safe handle, lowercase, dash-separated. Unique per company.
  // Generated from full_name at signup; stable across name changes
  // unless explicitly rotated. See lib/slug.ts.
  // Nullable at the DB level for backfill purposes — app code always
  // populates it on insert; a follow-up migration will enforce NOT NULL
  // once we're sure every row has one.
  slug           String?
  fullName       String     @map("full_name")
  avatarInitials String?    @map("avatar_initials")
  avatarUrl      String?    @map("avatar_url")
  bio            String?
  socialInstagram String?   @map("social_instagram")
  socialLinkedin  String?   @map("social_linkedin")
  socialWhatsapp  String?   @map("social_whatsapp")
  languages      String[]   @default([])
  // Member's personal theme for /profile/[slug]. One of PROFILE_THEMES
  // (lib/profile-themes.ts). Null reads as "dark". See decision 0020.
  profileTheme   String?    @default("dark") @map("profile_theme")
  accessTier     AccessTier @default(member) @map("access_tier")
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedTasks Task[]  @relation("TaskAssignee")
  createdTasks  Task[]  @relation("TaskCreatedBy")
  handoffsFrom  Handoff[] @relation("HandoffFrom")
  handoffsTo    Handoff[] @relation("HandoffTo")
  comments      TaskComment[] @relation("CommentAuthor")
  activityLogs  ActivityLog[] @relation("ActivityActor")
  externalRefs  TaskExternalRef[] @relation("ExternalRefCreatedBy")
  projectExternalRefs ProjectExternalRef[] @relation("ProjectExternalRefCreatedBy")

  @@unique([companyId, email])
  @@unique([companyId, slug])
  @@map("crew_member")
}

model Project {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String      @map("company_id") @db.Uuid
  name        String
  kind        ProjectKind @default(standard)
  isArchived  Boolean     @default(false) @map("is_archived")
  // GitHub repo for this project, in "org/name" form (e.g. "verbivore/web").
  // Drives #123 shortcut expansion and the "open repo" link on the project
  // card. NULL = no repo linked.
  githubRepo  String?     @map("github_repo")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks        Task[]
  cycles       Cycle[]
  externalRefs ProjectExternalRef[]

  @@unique([companyId, name])
  @@map("project")
}

model Task {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String       @map("company_id") @db.Uuid
  projectId   String       @map("project_id") @db.Uuid
  title       String
  description String?
  status      TaskStatus   @default(backlog)
  priority    TaskPriority @default(none)
  ref         String?      // Human-readable display ID, e.g. "SKAM-101"
  seqNumber   Int?         @map("seq_number") // Auto-increment per project for ref
  // Within-column ordering for the /dashboard board (decision 0022, slice 3b
  // drag-and-drop). Smaller = higher in the column. Nullable: rows seeded
  // before the migration use createdAt as the fallback order.
  sortOrder   Int?         @map("sort_order")
  assigneeId  String?      @map("assignee_id") @db.Uuid
  dueDate     DateTime?    @map("due_date") @db.Date
  createdBy   String?      @map("created_by") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project    Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   CrewMember?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator    CrewMember?         @relation("TaskCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  handoff    Handoff?
  labels     TaskLabel[]
  checklist  TaskChecklistItem[]
  comments   TaskComment[]
  depsOut    TaskDependency[]    @relation("TaskDepsOut")
  depsIn     TaskDependency[]    @relation("TaskDepsIn")
  cycleTasks CycleTask[]
  externalRefs TaskExternalRef[]

  @@index([companyId])
  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@map("task")
}

enum ExternalRefKind {
  issue
  pr
  commit
  doc
  link

  @@map("external_ref_kind")
}

model TaskExternalRef {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String          @map("company_id") @db.Uuid
  taskId    String          @map("task_id") @db.Uuid
  kind      ExternalRefKind
  url       String
  label     String?
  createdBy String?         @map("created_by") @db.Uuid
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  task    Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  creator CrewMember? @relation("ExternalRefCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@map("task_external_ref")
}

// Project-scoped sibling of TaskExternalRef. Same enum, same URL parser —
// just attached to the project rather than a single task. Used for cross-
// task artifacts like brief docs, audit trackers, brand guides.
model ProjectExternalRef {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String          @map("company_id") @db.Uuid
  projectId String          @map("project_id") @db.Uuid
  kind      ExternalRefKind
  url       String
  label     String?
  createdBy String?         @map("created_by") @db.Uuid
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  company  Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project  Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator  CrewMember? @relation("ProjectExternalRefCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@map("project_external_ref")
}

model Label {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String      @map("company_id") @db.Uuid
  name      String
  color     String?

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks   TaskLabel[]

  @@unique([companyId, name])
  @@map("label")
}

model TaskLabel {
  taskId  String @map("task_id") @db.Uuid
  labelId String @map("label_id") @db.Uuid

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@map("task_label")
}

model TaskDependency {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String       @map("company_id") @db.Uuid
  taskId          String       @map("task_id") @db.Uuid
  dependsOnTaskId String       @map("depends_on_task_id") @db.Uuid
  kind            RelationKind
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  task      Task @relation("TaskDepsOut", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskDepsIn", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@map("task_dependency")
}

model TaskChecklistItem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId    String  @map("task_id") @db.Uuid
  text      String
  isDone    Boolean @default(false) @map("is_done")
  sortOrder Int     @default(0) @map("sort_order")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_checklist_item")
}

model TaskComment {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  taskId    String    @map("task_id") @db.Uuid
  authorId  String?   @map("author_id") @db.Uuid
  body      String
  mentions  String[]  @default([])
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  // Set when the author (or an admin) edits the comment. Null means
  // never edited — render an "(edited)" tag when non-null.
  editedAt  DateTime? @map("edited_at") @db.Timestamptz(6)

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  task    Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author  CrewMember? @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@map("task_comment")
}

model ActivityLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor   CrewMember? @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([entityType, entityId])
  @@map("activity_log")
}

model Cycle {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String      @map("company_id") @db.Uuid
  projectId   String      @map("project_id") @db.Uuid
  number      Int
  name        String
  description String?
  // External planning doc (Google Doc, GitHub wiki, Notion, etc). Surfaced
  // as a clickable doc icon on the cycle hero + card.
  docUrl      String?     @map("doc_url")
  status      CycleStatus @default(upcoming)
  fromDate    DateTime    @map("from_date") @db.Date
  toDate      DateTime    @map("to_date") @db.Date
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   CycleTask[]

  @@unique([projectId, number])
  @@map("cycle")
}

model CycleTask {
  cycleId String @map("cycle_id") @db.Uuid
  taskId  String @map("task_id") @db.Uuid

  cycle Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([cycleId, taskId])
  @@map("cycle_task")
}

model Handoff {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String        @map("company_id") @db.Uuid
  taskId        String        @unique @map("task_id") @db.Uuid
  fromMemberId  String?       @map("from_member_id") @db.Uuid
  toMemberId    String?       @map("to_member_id") @db.Uuid
  status        HandoffStatus @default(in_progress)

  // Seven nullable text fields. `is_complete` is computed in TypeScript via
  // lib/handoff.ts (all seven non-null + non-empty after trim). See
  // docs/decisions/0015-slice-2-handoff-architecture.md.
  whatItIs       String? @map("what_it_is")
  currentStatus  String? @map("current_status")
  doneSoFar      String? @map("done_so_far")
  stillLeft      String? @map("still_left")
  fileLinks      String? @map("file_links")
  gotchas        String?
  whoToAsk       String? @map("who_to_ask")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  task       Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromMember CrewMember? @relation("HandoffFrom", fields: [fromMemberId], references: [id], onDelete: SetNull)
  toMember   CrewMember? @relation("HandoffTo", fields: [toMemberId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([toMemberId])
  @@map("handoff")
}
